    },
    data: {
        q: query,
        source: 'ko',
        target: 'en-US',
        format: 'text'
    }
  };

  const fetchData = async () => {
    setIsLoading(true);
    console.log(`[googleTranslate] Translating: "${query}"`);
    try {
      const response = await axios.request(options);
      const translated = response.data.data.translations[0].translatedText;
