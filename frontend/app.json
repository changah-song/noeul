{
  "expo": {
    "name": "Noeul",
    "slug": "Noeul",
    "scheme": "noeul",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#333B46"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon-ios.png",
      "bundleIdentifier": "com.noeulapp.Noeul"
    },
    "android": {
      "allowBackup": true,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#333B46"
      },
      "package": "com.noeulapp.Noeul"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "432f2363-e118-4789-8150-3b386f47cf00"
      }
    }
  }
}
